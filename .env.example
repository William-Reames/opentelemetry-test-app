# Flask Application Configuration
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=30

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=documents

# Tracing Backend Configuration
# Options: traceloop, langfuse, traceloop,langfuse, none
# Default: traceloop (for backward compatibility)
TRACING_BACKEND=traceloop

# OpenLLMetry / Traceloop Configuration (required if TRACING_BACKEND includes 'traceloop')
# Get your API key from https://app.traceloop.com
TRACELOOP_API_KEY=your_api_key_here
TRACELOOP_DISABLE_BATCH=false

# LangFuse Configuration (required if TRACING_BACKEND includes 'langfuse')
# Generate keys from your LangFuse instance UI (Settings > API Keys)
# For local setup: http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=http://localhost:3000

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=ai-tracing-prototype
OTEL_LOG_LEVEL=info