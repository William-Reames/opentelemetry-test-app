# Flask Application Configuration
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=30

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=documents

# OpenLLMetry / Traceloop Configuration (Cloud-based service - optional)
# Traceloop is a cloud service that requires signup at https://app.traceloop.com
# For local-only observability, leave this commented out and use Langfuse + Grafana instead
# TRACELOOP_API_KEY=your_api_key_here
# TRACELOOP_DISABLE_BATCH=false

# Langfuse Configuration (Optional)
# For self-hosted: http://localhost:3002
# For cloud: https://cloud.langfuse.com
# Get your keys from Langfuse project settings
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3002

# Grafana/Tempo Configuration (Optional)
# Enable Grafana stack integration
ENABLE_GRAFANA=false
TEMPO_ENDPOINT=http://localhost:4317

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=ai-tracing-prototype
OTEL_LOG_LEVEL=info